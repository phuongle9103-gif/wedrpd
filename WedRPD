name: RDP

on:
  workflow_dispatch:
    inputs:
      session_duration:
        description: 'Session duration in minutes (max 360)'
        required: false
        default: '360'
        type: string

jobs:
  secure-rdp:
    runs-on: windows-latest
    timeout-minutes: 360
    permissions:
      contents: read

    steps:
      - name: Verify Secrets
        run: |
          if (-not $env:TAILSCALE_AUTH_KEY) {
              Write-Error "TAILSCALE_AUTH_KEY secret is not set"
              exit 1
          }
          Write-Host "✓ Secrets verified"
        env:
          TAILSCALE_AUTH_KEY: ${{ secrets.TAILSCALE_AUTH_KEY }}

      - name: Configure Core RDP Settings
        run: |
          Write-Host "Configuring RDP settings..."
          
          try {
              # Enable Remote Desktop
              Set-ItemProperty -Path 'HKLM:\System\CurrentControlSet\Control\Terminal Server' `
                -Name "fDenyTSConnections" -Value 0 -Force
              
              # Enable Network Level Authentication (for security)
              Set-ItemProperty -Path 'HKLM:\System\CurrentControlSet\Control\Terminal Server\WinStations\RDP-Tcp' `
                -Name "UserAuthentication" -Value 1 -Force
              
              # Set Security Layer to highest
              Set-ItemProperty -Path 'HKLM:\System\CurrentControlSet\Control\Terminal Server\WinStations\RDP-Tcp' `
                -Name "SecurityLayer" -Value 2 -Force
              
              # Set encryption level to high
              Set-ItemProperty -Path 'HKLM:\System\CurrentControlSet\Control\Terminal Server\WinStations\RDP-Tcp' `
                -Name "MinEncryptionLevel" -Value 3 -Force

              # Configure firewall
              Write-Host "Configuring firewall..."
              netsh advfirewall firewall delete rule name="RDP-Tailscale" 2>$null
              
              # Allow incoming RDP connections only on Tailscale
              netsh advfirewall firewall add rule name="RDP-Tailscale" `
                dir=in action=allow protocol=TCP localport=3389 enable=yes description="RDP via Tailscale"
              
              # Restart RDP service
              Write-Host "Restarting RDP service..."
              Restart-Service -Name TermService -Force
              Start-Sleep -Seconds 2
              
              Write-Host "✓ RDP configuration completed"
          }
          catch {
              Write-Error "Failed to configure RDP: $_"
              exit 1
          }

      - name: Create RDP User
        run: |
          Write-Host "Creating RDP user..."
          
          try {
              $password = "5436"
              
              # Check if user already exists
              $existingUser = Get-LocalUser -Name "RDP" -ErrorAction SilentlyContinue
              if ($existingUser) {
                  Write-Host "Removing existing RDP user..."
                  Remove-LocalUser -Name "RDP" -Force
                  Start-Sleep -Seconds 1
              }
              
              # Create user
              $securePass = ConvertTo-SecureString $password -AsPlainText -Force
              New-LocalUser -Name "RDP" -Password $securePass -PasswordNeverExpires -ErrorAction Stop | Out-Null
              
              # Add to groups
              Add-LocalGroupMember -Group "Administrators" -Member "RDP" -ErrorAction Stop
              Add-LocalGroupMember -Group "Remote Desktop Users" -Member "RDP" -ErrorAction Stop
              
              # Save password to GitHub env (will be masked)
              Write-Host "::add-mask::$password"
              Add-Content -Path $env:GITHUB_ENV -Value "RDP_PASSWORD=$password"
              
              Write-Host "✓ RDP user created successfully"
          }
          catch {
              Write-Error "Failed to create RDP user: $_"
              exit 1
          }

      - name: Install Tailscale
        run: |
          Write-Host "Installing Tailscale..."
          
          try {
              $tsUrl = "https://pkgs.tailscale.com/stable/tailscale-setup-1.82.0-amd64.msi"
              $installerPath = "$env:TEMP\tailscale-installer.msi"
              
              Write-Host "Downloading Tailscale..."
              [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
              Invoke-WebRequest -Uri $tsUrl -OutFile $installerPath -TimeoutSec 60 -ErrorAction Stop
              
              if (-not (Test-Path $installerPath)) {
                  Write-Error "Tailscale installer download failed"
                  exit 1
              }
              
              Write-Host "Installing Tailscale MSI package..."
              $process = Start-Process -FilePath msiexec.exe `
                -ArgumentList "/i", "`"$installerPath`"", "/quiet", "/norestart" `
                -PassThru -Wait -NoNewWindow
              
              if ($process.ExitCode -ne 0) {
                  Write-Error "Tailscale installation failed with exit code $($process.ExitCode)"
                  exit 1
              }
              
              Remove-Item $installerPath -Force -ErrorAction SilentlyContinue
              
              Start-Sleep -Seconds 3
              Write-Host "✓ Tailscale installed successfully"
          }
          catch {
              Write-Error "Failed to install Tailscale: $_"
              exit 1
          }

      - name: Start Tailscale
        run: |
          Write-Host "Starting Tailscale..."
          
          try {
              $tailscaleExe = "$env:ProgramFiles\Tailscale\tailscale.exe"
              
              if (-not (Test-Path $tailscaleExe)) {
                  Write-Error "Tailscale executable not found at $tailscaleExe"
                  exit 1
              }
              
              # Connect to Tailscale with auth key
              & $tailscaleExe up --authkey=${{ secrets.TAILSCALE_AUTH_KEY }} `
                --hostname=gh-runner-$env:GITHUB_RUN_ID --force-reauth
              
              Start-Sleep -Seconds 2
              Write-Host "✓ Tailscale started"
          }
          catch {
              Write-Error "Failed to start Tailscale: $_"
              exit 1
          }

      - name: Get Tailscale IP
        run: |
          Write-Host "Waiting for Tailscale IP assignment..."
          
          $tailscaleExe = "$env:ProgramFiles\Tailscale\tailscale.exe"
          $maxRetries = 30
          $retryCount = 0
          
          while ($retryCount -lt $maxRetries) {
              try {
                  $tsIP = & $tailscaleExe ip -4 2>$null
                  
                  if ($tsIP -and $tsIP.Length -gt 0) {
                      $tsIP = $tsIP.Trim()
                      Write-Host "✓ Tailscale IP acquired: $tsIP"
                      Add-Content -Path $env:GITHUB_ENV -Value "TAILSCALE_IP=$tsIP"
                      exit 0
                  }
              }
              catch {
                  Write-Host "Attempt $($retryCount + 1)/$maxRetries failed, retrying..."
              }
              
              Start-Sleep -Seconds 2
              $retryCount++
          }
          
          Write-Error "Failed to acquire Tailscale IP after $($maxRetries * 2) seconds"
          exit 1

      - name: Test RDP Port
        run: |
          Write-Host "Testing RDP connectivity..."
          
          if (-not $env:TAILSCALE_IP) {
              Write-Error "TAILSCALE_IP environment variable not set"
              exit 1
          }
          
          Write-Host "Testing connection to $env:TAILSCALE_IP on port 3389..."
          
          try {
              $result = Test-NetConnection -ComputerName $env:TAILSCALE_IP `
                -Port 3389 -WarningAction SilentlyContinue -ErrorAction Stop
              
              if ($result.TcpTestSucceeded) {
                  Write-Host "✓ RDP port 3389 is accessible on Tailscale network"
              }
              else {
                  Write-Error "RDP port 3389 test failed"
                  exit 1
              }
          }
          catch {
              Write-Error "Connection test error: $_"
              exit 1
          }

      - name: Display Access Information
        run: |
          Write-Host ""
          Write-Host "╔═════════════════════════════════════════════════════════╗"
          Write-Host "║        RDP ACCESS INFORMATION - KEEP SECURE             ║"
          Write-Host "╠═════════════════════════════════════════════════════════╣"
          Write-Host "║ Tailscale IP  : $env:TAILSCALE_IP"
          Write-Host "║ Port          : 3389"
          Write-Host "║ Username      : RDP"
          Write-Host "║ Password      : $env:RDP_PASSWORD"
          Write-Host "║"
          Write-Host "║ Connection    : via Tailscale (secure VPN)"
          Write-Host "╚═════════════════════════════════════════════════════════╝"
          Write-Host ""
          Write-Host "⚠️  SECURITY NOTES:"
          Write-Host "   • Store credentials securely"
          Write-Host "   • Password will not be shown again"
          Write-Host "   • Connection is encrypted via Tailscale"
          Write-Host "   • Session will timeout after specified duration"
          Write-Host ""

      - name: Keep Session Alive
        run: |
          Write-Host "RDP session is now active. Keeping connection alive..."
          
          $sessionDuration = "${{ github.event.inputs.session_duration }}"
          if ([string]::IsNullOrEmpty($sessionDuration)) {
              $sessionDuration = 360
          }
          
          [int]$maxMinutes = [math]::Min([int]$sessionDuration, 360)
          Write-Host "Session will stay active for approximately $maxMinutes minutes"
          Write-Host ""
          
          $startTime = Get-Date
          $endTime = $startTime.AddMinutes($maxMinutes)
          
          while ((Get-Date) -lt $endTime) {
              $elapsed = (Get-Date) - $startTime
              $remaining = $endTime - (Get-Date)
              
              Write-Host "[$(Get-Date -Format 'HH:mm:ss')] Active: $($elapsed.Hours)h $($elapsed.Minutes)m | Remaining: $($remaining.Hours)h $($remaining.Minutes)m"
              
              Start-Sleep -Seconds 60
          }
          
          Write-Host "Session timeout reached. Cleaning up..."
